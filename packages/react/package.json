{
  "name": "@framie/react",
  "version": "0.1.0",
  "description": "Framie React bindings",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@framie/core": "0.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.12",
    "react": "^19.0.0"
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean",
    "dev": "tsup src/index.tsx --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
